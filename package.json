{
    "private": true,
    "type": "module",
    "scripts": {
        "srv": "php artisan serve",
        "dev": "vite",
        "autoload": "./scripts/dump-autoload.sh",
        "db:install": "./scripts/installDb.sh",
        "build": "vite build",
        "test": "vite test",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "clean": "rm -rf node_modules package-lock.json",
        "clean:node": "rm -rf node_modules",
        "clean:cache": "rm -rf node_modules/.cache",
        "clean:modules": "rm -rf node_modules && rm -rf package-lock.json",
        "clean:all": "npm run clean && npm run clean:node && npm run clean:cache && npm run clean:modules",
        "build:prod": "cross-env NODE_ENV=production vite build",
        "build:dev": "cross-env NODE_ENV=development vite build",
        "watch": "vite build --watch",
        "serve": "vite preview",
        "preview": "vite preview",
        "php:test": "php artisan test",
        "migrate": "php artisan migrate",
        "runMig": "./scripts/runMig.sh",
        "php:refresh": "php artisan migrate:refresh",
        "php:seed": "php artisan db:seed",
        "new:model": "./scripts/makeModel.sh",
        "new:controller": "./scripts/makeController.sh",
        "new:lw": "./scripts/makeLivewire.sh",
        "crud": "./scripts/generate_crud_views.sh",
        "component": "./scripts/newComponent.sh"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "alpinejs": "^3.13.7",
        "autoprefixer": "^10.4.2",
        "axios": "^1.6.4",
        "cross-env": "^7.0.3",
        "laravel-vite-plugin": "^1.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^5.0.0"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^6.5.1",
        "sass": "^1.71.1"
    }
}
